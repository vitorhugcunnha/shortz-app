<% if (user) { %>
    <!-- Navbar para Usuário Logado -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand" href="/feed">
                <i class="bi bi-play-fill"></i> SHORTZ
            </a>

            <!-- Campo de Busca -->
            <form class="d-none d-md-flex mx-auto" style="width: 40%;">
                <div class="input-group">
                    <input type="text" class="form-control bg-light border-0"
                        placeholder="Pesquisar vídeos ou usuários..." style="border-radius: 20px 0 0 20px;">
                    <button class="btn btn-light border-0" type="button" style="border-radius: 0 20px 20px 0;">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center">
                <a href="/upload" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block">
                    <i class="bi bi-plus-square me-1"></i> Upload
                </a>
                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle" id="dropdownUser"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="<%= user.profilePicture ? 
                            '/uploads/profiles/' + user.profilePicture : 
                            '/images/default-profile.png' %>" 
                            alt="<%= user.username %>" width="32" height="32" class="bg-secondary">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2" href="/profile/edit"><i class="bi bi-person me-2"></i> Ver
                                Perfil</a></li>
                        <li><a class="dropdown-item py-2" href="/my-videos"><i class="bi bi-camera-video me-2"></i> Meus
                                Vídeos</a></li>
                        <li><a class="dropdown-item py-2" href="/settings"><i class="bi bi-gear me-2"></i>
                                Configurações</a></li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>
                        <li><a class="dropdown-item py-2 text-danger" href="/logout"><i
                                    class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>
<% } else { %>
    <!-- Navbar para Visitante (Não Logado) -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-play-fill"></i> SHORTZ-APP
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-primary px-4 me-2" href="/login">Entrar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-4" href="/register">Criar Conta</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
<% } %>